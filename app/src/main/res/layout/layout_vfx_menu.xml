<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/vfx_menu_root"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_glass_menu"
    android:padding="12dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="VFX Settings"
        android:textColor="#FFFFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Glow Intensity"
        android:textColor="#AAFFFFFF"
        android:textSize="12sp" />

    <SeekBar
        android:id="@+id/seek_glow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="50"
        android:progressTint="#DF00FF"
        android:thumbTint="#FFFFFF" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pulse Speed"
        android:textColor="#AAFFFFFF"
        android:textSize="12sp"
        android:layout_marginTop="8dp" />

    <SeekBar
        android:id="@+id/seek_pulse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:max="100"
        android:progress="50"
        android:progressTint="#00FFFF"
        android:thumbTint="#FFFFFF" />

    <include
        android:id="@+id/sw_electric_arc"
        layout="@layout/item_menu_switch" />

    <Button
        android:id="@+id/btn_close_vfx"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:layout_marginTop="8dp"
        android:text="✕"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:background="#33FF0000" />
</LinearLayout>
