<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="#1A0A2E"
    app:cardCornerRadius="8dp"
    app:cardElevation="0dp"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/bg_glass_input_neon">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtLogTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="14:05:22"
                android:textColor="#00FF88"
                android:textSize="11sp"
                android:fontFamily="monospace"/>

            <TextView
                android:id="@+id/txtLogStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SCAN_OK"
                android:textColor="#00FFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"/>
        </LinearLayout>

        <TextView
            android:id="@+id/txtLogHwid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="HWID: LUX-XXXX-XXXX"
            android:textColor="#A0A0A0"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:layout_marginTop="4dp"/>

        <TextView
            android:id="@+id/txtLogVersion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ver: 5.12.0"
            android:textColor="#FF69B4"
            android:textSize="10sp"
            android:fontFamily="monospace"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
