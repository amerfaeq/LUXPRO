<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#261A0033"
    app:cardCornerRadius="14dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@drawable/bg_glass_input_neon">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageView
                android:id="@+id/imgPin"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#FFD700"
                android:layout_marginEnd="8dp"
                android:visibility="gone"/>

            <TextView
                android:id="@+id/txtAnnTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/ann_title_hint"
                android:textColor="#DF00FF"
                android:fontFamily="sans-serif-condensed"
                android:textStyle="bold"
                android:textSize="17sp" />
                
            <TextView
                android:id="@+id/txtAnnDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/now"
                android:textColor="#888888"
                android:textSize="11sp"
                android:fontFamily="monospace"/>
        </LinearLayout>

        <TextView
            android:id="@+id/txtAnnContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ann_content_hint"
            android:textColor="#E0E0E0"
            android:fontFamily="monospace"
            android:textSize="13sp"
            android:lineSpacingExtra="4dp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/btnAnnLink"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="@string/ann_link_btn_normal"
            android:textColor="#00FFFF"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:textStyle="bold"
            android:background="@drawable/bg_neon_button_secondary"
            app:backgroundTint="@null"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:visibility="gone"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
