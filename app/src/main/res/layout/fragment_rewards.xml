<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:gravity="center_horizontal">

        <!-- ══════════ HEADER ══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rewards_title"
                android:textColor="#FFD700"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:letterSpacing="0.15"
                android:shadowColor="#FFD700"
                android:shadowRadius="20"
                android:shadowDx="0"
                android:shadowDy="0"/>

            <View
                android:layout_width="200dp"
                android:layout_height="1dp"
                android:layout_marginTop="6dp"
                android:background="#80FFD700"/>
        </LinearLayout>

        <!-- ══════════ REWARD CHEST SECTION ══════════ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <!-- Glow Background -->
            <View
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_chest_glow"/>

            <!-- Chest Image -->
            <ImageView
                android:id="@+id/imgChest"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:layout_gravity="center"
                android:src="@drawable/chest_closed"
                android:visibility="gone"/>
        </FrameLayout>

        <!-- ══════════ COUNTDOWN PANEL ══════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardCountdown"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#00000000"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp"
                android:background="@drawable/bg_glass_input_neon">

                <!-- Section Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rewards_next_timer_label"
                    android:textColor="#AAAAAA"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="12dp"/>

                <!-- LED‑Style Time Boxes -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Hours -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/txtHours"
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:text="00"
                            android:textColor="#00FFFF"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:gravity="center"
                            android:background="@drawable/bg_glass_input_neon"
                            android:shadowColor="#00FFFF"
                            android:shadowRadius="18"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/rewards_hour_unit"
                            android:textColor="#808080"
                            android:textSize="10sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" : "
                        android:textColor="#DF00FF"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:shadowColor="#DF00FF"
                        android:shadowRadius="10"
                        android:paddingBottom="16dp"/>

                    <!-- Minutes -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/txtMinutes"
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:text="00"
                            android:textColor="#00FFFF"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:gravity="center"
                            android:background="@drawable/bg_glass_input_neon"
                            android:shadowColor="#00FFFF"
                            android:shadowRadius="18"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/rewards_minute_unit"
                            android:textColor="#808080"
                            android:textSize="10sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=" : "
                        android:textColor="#DF00FF"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:shadowColor="#DF00FF"
                        android:shadowRadius="10"
                        android:paddingBottom="16dp"/>

                    <!-- Seconds -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/txtSeconds"
                            android:layout_width="70dp"
                            android:layout_height="70dp"
                            android:text="00"
                            android:textColor="#00FFFF"
                            android:textSize="36sp"
                            android:textStyle="bold"
                            android:fontFamily="monospace"
                            android:gravity="center"
                            android:background="@drawable/bg_glass_input_neon"
                            android:shadowColor="#00FFFF"
                            android:shadowRadius="18"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/rewards_second_unit"
                            android:textColor="#808080"
                            android:textSize="10sp"
                            android:fontFamily="monospace"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Hidden original timerDisplay (kept for compatibility) -->
                <TextView
                    android:id="@+id/timerDisplay"
                    android:visibility="gone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ══════════ GIFT READY BADGE ══════════ -->
        <LinearLayout
            android:id="@+id/layoutGiftReady"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginBottom="16dp"
            android:padding="20dp"
            android:background="@drawable/bg_glass_input_neon">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rewards_ready_msg"
                android:textColor="#FFD700"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:shadowColor="#FFD700"
                android:shadowRadius="20"
                android:layout_marginBottom="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rewards_click_hint"
                android:textColor="#AAAAAA"
                android:textSize="13sp"
                android:gravity="center"/>
        </LinearLayout>

        <!-- ══════════ CLAIM BUTTON ══════════ -->
        <Button
            android:id="@+id/btnShowGift"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="@string/rewards_get_btn"
            android:background="@drawable/bg_neon_button_primary"
            app:backgroundTint="@null"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.1"
            android:textSize="18sp"
            android:elevation="12dp"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <!-- ══════════ REWARD KEY PANEL ══════════ -->
        <LinearLayout
            android:id="@+id/layoutGiftDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:padding="20dp"
            android:background="@drawable/bg_glass_input_neon">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rewards_global_key_label"
                android:textColor="#DF00FF"
                android:textStyle="bold"
                android:fontFamily="sans-serif-condensed"
                android:textSize="16sp"
                android:shadowColor="#DF00FF"
                android:shadowRadius="10"
                android:layout_marginBottom="16dp"/>

            <!-- Key Display Box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_glass_input_neon"
                android:padding="12dp">

                <TextView
                    android:id="@+id/txtRewardKey"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="LUX-XXXXXXXX"
                    android:textColor="#FFD700"
                    android:fontFamily="monospace"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:gravity="center"
                    android:padding="10dp"
                    android:shadowColor="#FFD700"
                    android:shadowRadius="12"/>

                <Button
                    android:id="@+id/btnCopyRewardKey"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rewards_copy_btn"
                    android:textSize="13sp"
                    android:background="@drawable/bg_neon_button_primary"
                    app:backgroundTint="@null"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-condensed"
                    android:paddingEnd="16dp"
                    android:paddingStart="16dp"/>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/rewards_save_hint"
                android:textColor="#888888"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>