<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/bg_glass_input_neon"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtAdminAnnTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/ann_title_hint"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="14sp"
            android:fontFamily="sans-serif-condensed"/>

        <TextView
            android:id="@+id/txtAdminAnnDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/admin_add_success"/><!-- Reusing success to avoid too many keys -->
            android:textColor="#A0A0A0"
            android:textSize="11sp"
            android:fontFamily="monospace"/>

    </LinearLayout>

    <ImageButton
        android:id="@+id/btnAdminDeleteAnn"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@android:drawable/ic_menu_delete"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:tint="#FF4444"
        android:contentDescription="@string/delete_ann_desc" />

</LinearLayout>
