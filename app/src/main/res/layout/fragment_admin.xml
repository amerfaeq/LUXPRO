<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/admin_title"
            android:textColor="#DF00FF"
            android:textSize="22sp"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:letterSpacing="0.05"
            android:shadowColor="#DF00FF"
            android:shadowRadius="10"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <!-- Key Gen -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#261A0033"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_glass_input_neon">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_keygen_gen_title"
                    android:textColor="#00FFFF"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_keygen_days"
                    android:textColor="#A0A0A0"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/edKeyDays"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/admin_keygen_days_hint"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:inputType="number"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_keygen_count"
                    android:textColor="#A0A0A0"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/edKeyCount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/admin_keygen_count_hint"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:inputType="number"
                    android:layout_marginBottom="20dp"/>

                <Button
                    android:id="@+id/btnGenerateKeys"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="@string/admin_keygen_gen_btn"
                    android:background="@drawable/bg_neon_button_primary"
                    app:backgroundTint="@null"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:id="@+id/txtGeneratedKeys"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#00FF88"
                    android:textSize="13sp"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="16dp"
                    android:visibility="gone"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="12dp"/>

                <Button
                    android:id="@+id/btnCopyKeys"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/admin_copy_btn"
                    android:background="@drawable/bg_neon_button_secondary"
                    app:backgroundTint="@null"
                    android:textColor="#00FFFF"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:visibility="gone"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Reward Mgt -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#261A0033"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_glass_input_neon">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_reward_title"
                    android:textColor="#DF00FF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_reward_pass"
                    android:textColor="#A0A0A0"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/edGiftPassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/admin_reward_pass_hint"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/txtCurrentReward"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_reward_status"
                    android:textColor="#FFD700"
                    android:textSize="12sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnUpdateReward"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="@string/admin_reward_btn"
                    android:background="@drawable/bg_neon_button_primary"
                    app:backgroundTint="@null"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-condensed"
                    android:letterSpacing="0.05"
                    android:textStyle="bold"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- User Mgt -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#261A0033"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_glass_input_neon">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_user_title"
                    android:textColor="#FFD700"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/edUserUid"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/admin_user_uid"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/edExtendDays"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/admin_user_days"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:inputType="number"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/txtUserInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#00FF88"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <Button
                        android:id="@+id/btnSearchUser"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:text="@string/admin_user_scan"
                        android:background="@drawable/bg_neon_button_secondary"
                        app:backgroundTint="@null"
                        android:textColor="#00FFFF"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-condensed"
                        android:textStyle="bold"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btnExtendUser"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:text="@string/admin_user_extend"
                        android:background="@drawable/bg_neon_button_secondary"
                        app:backgroundTint="@null"
                        android:textColor="#FFD700"
                        android:textStyle="bold"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginEnd="6dp"/>

                    <Button
                        android:id="@+id/btnToggleUserActive"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:text="@string/admin_user_toggle"
                        android:background="@drawable/bg_neon_button_secondary"
                        app:backgroundTint="@null"
                        android:textColor="#DF00FF"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:textSize="12sp"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Announcements Mgt -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#261A0033"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_glass_input_neon">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ann_system_title"
                    android:textColor="#00FFFF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/edAnnTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/ann_title_hint"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/edAnnContent"
                    android:layout_width="match_parent"
                    android:layout_height="90dp"
                    android:hint="@string/ann_content_hint"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:gravity="top"
                    android:inputType="textMultiLine"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/edAnnLink"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/ann_link_hint"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp"/>

                <CheckBox
                    android:id="@+id/cbAnnPinned"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ann_pinned_label"
                    android:textColor="#FFD700"
                    android:fontFamily="monospace"
                    android:textSize="12sp"
                    android:layout_marginBottom="16dp"
                    android:buttonTint="#DF00FF"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="1">

                    <Button
                        android:id="@+id/btnPublishAnn"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="@string/ann_publish_btn"
                        android:background="@drawable/bg_neon_button_primary"
                        app:backgroundTint="@null"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:letterSpacing="0.05"/>
                </LinearLayout>

                <!-- خط فاصل -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#33DF00FF"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/ann_list_title"
                    android:textColor="#FFD700"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvAdminAnnouncements"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="true"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Resellers Mgt -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#261A0033"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_glass_input_neon">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_reseller_title"
                    android:textColor="#FF69B4"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="16dp"/>

                <EditText
                    android:id="@+id/edResellerName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/admin_reseller_name"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/edResellerTelegram"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/admin_reseller_tg"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_reseller_region"
                    android:textColor="#A0A0A0"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"/>
                <Spinner
                    android:id="@+id/spinnerCountry"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="8dp"
                    android:popupBackground="#1A0A2E"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/edResellerImageUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/admin_reseller_avatar"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btnAddReseller"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="@string/admin_reseller_add"
                        android:background="@drawable/bg_neon_button_primary"
                        app:backgroundTint="@null"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnDeleteReseller"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="@string/admin_reseller_del"
                        android:background="@drawable/bg_neon_button_secondary"
                        app:backgroundTint="@null"
                        android:textColor="#FF4444"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:textSize="12sp"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/txtResellerStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:textColor="#00FF88"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:padding="8dp"
                    android:layout_marginTop="8dp"
                    android:visibility="gone"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Upd Mgt -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#261A0033"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="30dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_glass_input_neon">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_force_update_title"
                    android:textColor="#FF4444"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_force_update_ver"
                    android:textColor="#A0A0A0"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/edUpdateVersion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/admin_force_update_ver_hint"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:inputType="number"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_force_update_url"
                    android:textColor="#A0A0A0"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:layout_marginBottom="8dp"/>
                <EditText
                    android:id="@+id/edUpdateApkUrl"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/admin_force_update_url_hint"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#555"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="14dp"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:id="@+id/txtCurrentVersion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_force_update_status"
                    android:textColor="#FF9999"
                    android:textSize="11sp"
                    android:fontFamily="monospace"
                    android:background="@drawable/bg_glass_input_neon"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btnPublishUpdate"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="@string/admin_force_update_btn"
                        android:background="@drawable/bg_neon_button_primary"
                        app:backgroundTint="@null"
                        android:textColor="#FFFFFF"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnDeleteUpdate"
                        android:layout_width="0dp"
                        android:layout_height="55dp"
                        android:layout_weight="1"
                        android:text="@string/delete_update_btn"
                        android:background="@drawable/bg_neon_button_secondary"
                        app:backgroundTint="@null"
                        android:textColor="#FF4444"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"
                        android:textSize="12sp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Sentinel Health Monitor (NEW) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#261A0033"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_glass_input_neon">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sentinel_title"
                    android:textColor="#00FF88"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="16dp"/>

                <!-- Global Status -->
                <LinearLayout
                    android:id="@+id/cardSentinelStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp"
                    android:background="@drawable/bg_glass_input_neon"
                    android:layout_marginBottom="16dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sentinel_status_label"
                        android:textColor="#A0A0A0"
                        android:textSize="11sp"
                        android:fontFamily="monospace"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/txtSentinelGlobalStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/sentinel_supported"
                        android:textColor="#00FF88"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-condensed"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/sentinel_feed_title"
                    android:textColor="#FFD700"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="12dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSentinelFeed"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:clipToPadding="false"
                    android:overScrollMode="never"
                    android:nestedScrollingEnabled="true"
                    android:layout_marginBottom="16dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <Button
                        android:id="@+id/btnDownloadTrace"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:text="@string/sentinel_btn_trace"
                        android:background="@drawable/bg_neon_button_secondary"
                        app:backgroundTint="@null"
                        android:textColor="#FFD700"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-condensed"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/btnPushOffset"
                        android:layout_width="0dp"
                        android:layout_height="50dp"
                        android:layout_weight="1"
                        android:text="@string/sentinel_btn_offset"
                        android:background="@drawable/bg_neon_button_secondary"
                        app:backgroundTint="@null"
                        android:textColor="#00FFFF"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-condensed"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Logout Section -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#261A0033"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            android:layout_marginBottom="30dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="@drawable/bg_glass_input_neon">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/logout_section_title"
                    android:textColor="#FF9999"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-condensed"
                    android:layout_marginBottom="16dp"/>

                <Button
                    android:id="@+id/btnAdminLogout"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="@string/logout_btn"
                    android:background="@drawable/bg_neon_button_secondary"
                    app:backgroundTint="@null"
                    android:textColor="#FF4444"
                    android:textSize="14sp"
                    android:fontFamily="sans-serif-condensed"
                    android:textStyle="bold"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>
